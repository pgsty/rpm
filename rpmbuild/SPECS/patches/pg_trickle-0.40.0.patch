Subject: Trim non-extension Cargo targets for packaging

The upstream tree includes auxiliary workspace members, a CLI binary, dev-only
test dependencies, benchmark targets, and a release profile tuned for upstream
distribution builds. For packaging we only need the PostgreSQL 18 extension
itself, so drop the extra targets and relax the release profile to keep
resource usage reasonable in builder containers.

--- a/Cargo.toml
+++ b/Cargo.toml
@@ -10,9 +10,6 @@
 keywords = ["postgresql", "streaming", "materialized-view", "incremental", "pgrx"]
 categories = ["database"]
 
-[workspace]
-members = [".", "pgtrickle-relay"]
-
 # Allow pgrx internal cfg values used by pg_shmem_init! macro
 [lints.rust]
 unexpected_cfgs = { level = "warn", check-cfg = ['cfg(feature, values("pg13", "pg14", "pg15", "pg16", "pg17"))'] }
@@ -20,13 +17,9 @@
 [lib]
 crate-type = ["cdylib", "lib"]
 
-[[bin]]
-name = "pg_trickle_dump"
-path = "./src/bin/pg_trickle_dump.rs"
-
 [features]
 default = ["pg18"]
-pg18 = ["pgrx/pg18", "pgrx-tests/pg18"]
+pg18 = ["pgrx/pg18"]
 pg_test = []
 light-e2e = []
 
@@ -41,36 +34,11 @@
 chrono = "0.4"
 postgres = "0.19"
 
-[dev-dependencies]
-pgrx-tests = "=0.18.0"
-testcontainers = "0.27"
-testcontainers-modules = { version = "0.15", features = ["postgres"] }
-tokio = { version = "1", features = ["rt-multi-thread", "macros", "process"] }
-sqlx = { version = "0.8", features = ["runtime-tokio", "postgres", "json"] }
-tokio-postgres = "0.7"
-serde_json = "1"
-regex-lite = "0.1"
-xxhash-rust = { version = "0.8", features = ["xxh64", "xxh3"] }
-proptest = "1"
-criterion = { version = "0.5", features = ["html_reports"] }
-
-[[bench]]
-name = "refresh_bench"
-harness = false
-
-[[bench]]
-name = "diff_operators"
-harness = false
-
-[[bench]]
-name = "scheduler_bench"
-harness = false
-
 [profile.dev]
 panic = "unwind"
 
 [profile.release]
 panic = "unwind"
 opt-level = 3
-lto = "fat"
-codegen-units = 1
+lto = "off"
+codegen-units = 16
