diff --git a/pg_documentdb_extended_rum/validate_rum_core_exports.sh b/pg_documentdb_extended_rum/validate_rum_core_exports.sh
--- a/pg_documentdb_extended_rum/validate_rum_core_exports.sh
+++ b/pg_documentdb_extended_rum/validate_rum_core_exports.sh
@@ -37,3 +37,3 @@ expectedPgExports=(
-# Extract globally visible (T/D/B) symbol names from each .so, excluding standard PG extension symbols
-leftExports=$(nm -D --defined-only "$leftLib" 2>/dev/null | awk '$2 ~ /^[TDB]$/ {print $3}' | grep -vxE '_PG_init|Pg_magic_func' | sort)
-rightExports=$(nm -D --defined-only "$rightLib" 2>/dev/null | awk '$2 ~ /^[TDB]$/ {print $3}' | grep -vxE '_PG_init|Pg_magic_func' | sort)
+# Exclude standard PG symbols and toolchain-provided ELF boundary symbols.
+leftExports=$(nm -D --defined-only "$leftLib" 2>/dev/null | awk '$2 ~ /^[TDB]$/ {print $3}' | grep -vxE '_PG_init|Pg_magic_func|__bss_end__|__bss_start|__bss_start__|__end__|_bss_end__|_edata|_end' | sort)
+rightExports=$(nm -D --defined-only "$rightLib" 2>/dev/null | awk '$2 ~ /^[TDB]$/ {print $3}' | grep -vxE '_PG_init|Pg_magic_func|__bss_end__|__bss_start|__bss_start__|__end__|_bss_end__|_edata|_end' | sort)
