Subject: Compatibility fixes for EL8/EL9 builder libraries

EL9 ships hiredis 1.0.x, which exposes redisEnableKeepAlive() but not the
newer redisEnableKeepAliveWithInterval() helper used upstream. Keep the same
best-effort TCP keepalive behavior by using the interval-aware API when it is
available and falling back to the older helper otherwise.

EL8 ships libcurl 7.61, which predates curl_multi_poll(). Use
curl_multi_wait() there so the HTTP dispatcher still builds on the older curl
headers.

--- a/src/dispatchers/redis/redis_connection.c
+++ b/src/dispatchers/redis/redis_connection.c
@@ -140,7 +140,11 @@
      * 15s interval matches hiredis default. Must re-apply after reconnect
      * since redisReconnect() does not preserve keepalive settings. */
     if (redis->context) {
+#if defined(HIREDIS_MAJOR) && ((HIREDIS_MAJOR > 1) || (HIREDIS_MAJOR == 1 && HIREDIS_MINOR >= 1))
         redisEnableKeepAliveWithInterval(redis->context, 15);
+#else
+        redisEnableKeepAlive(redis->context);
+#endif
     }
 
     /* Authenticate if password provided (Redis 6+ ACL: AUTH username password) */
--- a/src/dispatchers/http/http_batch.c
+++ b/src/dispatchers/http/http_batch.c
@@ -186,12 +186,21 @@
 
             if (still_running > 0) {
                 int numfds;
+#if LIBCURL_VERSION_NUM >= 0x074200
                 mc = curl_multi_poll(http_dispatcher->multi_handle, NULL, 0, poll_interval_ms,
                                      &numfds);
                 if (mc != CURLM_OK) {
                     ulak_log("warning", "curl_multi_poll failed: %s", curl_multi_strerror(mc));
                     break;
                 }
+#else
+                mc = curl_multi_wait(http_dispatcher->multi_handle, NULL, 0, poll_interval_ms,
+                                     &numfds);
+                if (mc != CURLM_OK) {
+                    ulak_log("warning", "curl_multi_wait failed: %s", curl_multi_strerror(mc));
+                    break;
+                }
+#endif
             }
 
             clock_gettime(CLOCK_MONOTONIC, &now_time);
