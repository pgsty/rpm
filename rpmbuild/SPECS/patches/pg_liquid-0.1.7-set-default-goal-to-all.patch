Subject: Force the default make goal to the extension build

The upstream Makefile starts with packaging helper targets. Debian builds
invoke plain `make`, so set the default goal explicitly to `all` to avoid
running the PGXN validation path instead of the PGXS build.

--- a/Makefile
+++ b/Makefile
@@ -1,3 +1,5 @@
+.DEFAULT_GOAL := all
+
 DISTDIR := dist
 BUILD_SENTINEL ?= 0
 LEGACY_ARTIFACTS := src/pg_liquid.o src/engine.o src/scan.o src/catalog.o src/parser.o src/assertion_compiler.o \
