+    let oid = unsafe {
+        let am = heap_tuple_struct::<pgrx::pg_sys::FormData_pg_am>(tuple);
+        (*am).oid
+    };
+    unsafe { pgrx::pg_sys::ReleaseSysCache(tuple) };
+    Some(oid)
