From: Pigsty Packaging Team <rh@vonng.com>
Subject: Use a portable JVM link and reproducible Java bytecode

Use the JDK selected by the package recipe instead of the x86_64-only
/usr/lib64 default.  Resolve libjvm through a package-owned link beside the
extension and emit Java 8-compatible class files from all supported JDKs.

--- a/Makefile
+++ b/Makefile
@@ -13,29 +13,32 @@ REGRESS = postgresql/new_test postgresql/aggregates postgresql/date postgresql/
 
 JDBC_CONFIG = jdbc_config
 
-LIBDIR=/usr/lib64/
+LIBDIR ?= /usr/lib/jvm/java-openjdk/lib/server
 
 SHLIB_LINK += -L$(LIBDIR) -ljvm
 
 UNAME = $(shell uname)
 
 JAVA_SOURCES = \
 	JDBCUtils.java \
 	JDBCDriverLoader.java \
 	JDBCConnection.java \
 	resultSetInfo.java
 
 # Generate a list of .class files corresponding to .java files
 JAVA_CLASSES = $(patsubst %.java,%.class,$(JAVA_SOURCES))
 
 PG_CPPFLAGS=-D'SHARE_EXT_DIR=$(datadir)/extension' -I$(libpq_srcdir)
 
+JAVAC ?= javac
+JAVACFLAGS ?= --release 8
+
 # Target to compile all Java source files
 all:$(JAVA_CLASSES)
 
 # Rules for compiling each .java file into a .class
 %.class: %.java
-	javac $<
+	$(JAVAC) $(JAVACFLAGS) $<
 
 # Use DATA_built to install .class files
 DATA_built = $(JAVA_CLASSES)
