Subject: Force pgproto to use the bundled naive utf8_range path

The upstream PGXS build only links third_party/utf8_range/naive.o. On
architectures where utf8_range.h advertises utf8_range2() as an external
symbol, the build can otherwise end up referencing SIMD objects that are not
linked into the extension. Keep the header on the naive fallback path.

--- a/third_party/utf8_range/utf8_range.h
+++ b/third_party/utf8_range/utf8_range.h
@@ -5,14 +5,10 @@
 extern "C" {
 #endif
 
-#if (defined(__ARM_NEON) && defined(__aarch64__)) || defined(__SSE4_1__)
-int utf8_range2(const unsigned char* data, int len);
-#else
 int utf8_naive(const unsigned char* data, int len);
 static inline int utf8_range2(const unsigned char* data, int len) {
   return utf8_naive(data, len);
 }
-#endif
 
 #ifdef __cplusplus
 }  // extern "C"
