--- install_setup_intel_decimal_math_lib.sh
+++ install_setup_intel_decimal_math_lib.sh
@@ -60,2 +60,28 @@
-git fetch --depth 1 origin "$MATH_LIB_VERSION"
-git checkout FETCH_HEAD
+if timeout 60 git fetch --depth 1 origin "$MATH_LIB_VERSION"; then
+    git checkout FETCH_HEAD
+else
+    # Launchpad's git endpoint is occasionally unavailable. Reconstruct the
+    # same Ubuntu applied source from the official archive as a deterministic
+    # fallback so extension builds are not blocked by a transient TLS error.
+    MATH_RELEASE="${MATH_LIB_VERSION#applied/}"
+    MATH_UPSTREAM="${MATH_RELEASE%-*}"
+    UBUNTU_POOL="https://archive.ubuntu.com/ubuntu/pool/universe/i/intelrdfpmath"
+    PATCH_ROOT="$INSTALL_DEPENDENCIES_ROOT/intelrdfpmath-debian-$MATH_RELEASE"
+
+    cd "$INSTALL_DEPENDENCIES_ROOT"
+    rm -rf "$MATH_LIB_WITH_VERSION/lib/intelmathlib" "$PATCH_ROOT"
+    mkdir -p "$MATH_LIB_WITH_VERSION/lib/intelmathlib" "$PATCH_ROOT"
+    cd "$MATH_LIB_WITH_VERSION/lib/intelmathlib"
+    curl -fL --retry 3 \
+        "$UBUNTU_POOL/intelrdfpmath_${MATH_UPSTREAM}.orig.tar.gz" | tar -xz
+    curl -fL --retry 3 \
+        "$UBUNTU_POOL/intelrdfpmath_${MATH_RELEASE}.debian.tar.xz" | tar -xJ -C "$PATCH_ROOT"
+
+    while IFS= read -r patch_name; do
+        case "$patch_name" in
+            ''|'#'*) continue ;;
+        esac
+        patch -p1 < "$PATCH_ROOT/debian/patches/$patch_name"
+    done < "$PATCH_ROOT/debian/patches/series"
+    rm -rf "$PATCH_ROOT"
+fi
